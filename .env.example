# =============================================================================
# Tama Academy — variables d'environnement (EXEMPLE)
# Copier vers .env.local (dev) ; ne JAMAIS committer de secrets réels.
# Toutes les variables listées (y compris « Sprint ultérieur ») sont là pour
# pré-remplissage Samir : on les renseigne au fil de l'eau, on ne crée pas un
# 2e .env.example plus tard.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Clerk (auth parents / Sensei / admin)
# Dashboard : https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook « user.created » / sync (si activé)
CLERK_WEBHOOK_SECRET=whsec_...

# Nom du JWT template Clerk consommé par le client Supabase
# (Doit matcher le nom créé dans le dashboard Clerk — cf. docs/clerk-supabase-jwt-checklist.md §1.1)
CLERK_JWT_TEMPLATE_SUPABASE=supabase

# -----------------------------------------------------------------------------
# Supabase (Postgres + Realtime + Storage)
# Dashboard : https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...
# Uniquement serveur / CI / scripts — jamais exposé au navigateur
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# Optionnel : ID projet (scripts, MCP, support)
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Postgres (Drizzle)
# Deux connection strings — chacune a un usage strict (brief v2 §15).
# -----------------------------------------------------------------------------
# Pooler Supabase, mode transaction, port 6543 — runtime de l'app (Vercel
# Functions / Server Actions / Server Components). Préféré partout en prod.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ⚠️ Le pooler transaction mode (6543) ne supporte PAS les prepared statements
# ni les advisory locks. Côté Drizzle/postgres.js, configurer { prepare: false }.
# Pour les opérations qui nécessitent ces features (rare en runtime app),
# utiliser DATABASE_DIRECT_URL ponctuellement.

# Connexion directe au Postgres Supabase, port 5432 — RÉSERVÉE à
# `drizzle-kit migrate` / `drizzle-kit push` / `drizzle-kit studio`. Le pooler
# (port 6543, transaction mode) ne supporte pas les commandes DDL qu'utilise
# drizzle-kit ; sans cette variable, la première migration de PR #2 échoue.
# NE JAMAIS utiliser depuis le code applicatif.
DATABASE_DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# JWT session enfant (signing serveur — jose)
# Générer : openssl rand -base64 64   (512 bits, brief v2 §19)
# -----------------------------------------------------------------------------
JWT_CHILD_SECRET=
JWT_CHILD_ISSUER=tama-academy
JWT_CHILD_AUDIENCE=tama-child-session
JWT_CHILD_MAX_AGE_SECONDS=3600

# -----------------------------------------------------------------------------
# next-intl (si chemins locales par préfixe)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DEFAULT_LOCALE=fr
# NEXT_PUBLIC_LOCALES=fr,en,ar,es

# -----------------------------------------------------------------------------
# Observabilité
# -----------------------------------------------------------------------------
# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# Sprint ultérieur — laisser vide en Sprint 0
# Listé ici pour que Samir pré-remplisse au fil de l'eau (pas de second
# .env.example à maintenir).
# =============================================================================

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting, cache éphémère — Sprint 1)
# Dashboard : https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Stripe (paiements — Sprint ultérieur)
# Dashboard : https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend (emails transactionnels — Sprint ultérieur)
# Dashboard : https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tamaacademy.fr

# -----------------------------------------------------------------------------
# DigitalSamba (visio Stage — Sprint 4)
# Dashboard : https://dashboard.digitalsamba.com
# -----------------------------------------------------------------------------
DIGITALSAMBA_TEAM_ID=
DIGITALSAMBA_DEVELOPER_KEY=

# -----------------------------------------------------------------------------
# Divers / feature flags locaux
# -----------------------------------------------------------------------------
# LOG_LEVEL=debug
