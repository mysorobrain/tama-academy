# =============================================================================
# Tama Academy — variables d'environnement (EXEMPLE)
# Copier vers .env.local (dev) ; ne JAMAIS committer de secrets réels.
# Toutes les variables listées (y compris « Sprint ultérieur ») sont là pour
# pré-remplissage Samir : on les renseigne au fil de l'eau, on ne crée pas un
# 2e .env.example plus tard.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Clerk — authentification parents / Sensei / admin (PR #3)
# Dashboard : https://dashboard.clerk.com
# -----------------------------------------------------------------------------
# Clés publishable / secret de l'instance Clerk (dev = exotic-snail-90.clerk.accounts.dev).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Secret HMAC pour valider la signature svix des webhooks Clerk (PR #3 C4).
# À créer dans Dashboard → Webhooks → Add endpoint → copier le whsec_...
# Le endpoint pointe vers https://<tunnel-ngrok>/api/clerk/webhook en dev,
# et https://tama.academy/api/clerk/webhook en prod.
CLERK_WEBHOOK_SECRET=whsec_...

# Issuer et JWKS URL Clerk (utilisés par Supabase Third-Party Auth pour valider
# les JWT Clerk côté Postgres — auth.jwt() RLS user-aware en PR #3 C5).
# Ces deux valeurs sont aussi à coller dans :
#   Supabase Dashboard → Authentication → Providers → Third-Party Auth → Clerk
# (cette config dashboard ne peut PAS se faire en code — sync bloquant PR #3).
CLERK_ISSUER=https://exotic-snail-90.clerk.accounts.dev
CLERK_JWKS_URL=https://exotic-snail-90.clerk.accounts.dev/.well-known/jwks.json

# Nom du JWT template Clerk consommé par le client Supabase
# (Doit matcher le nom créé dans le dashboard Clerk — Issuer + claims
# { "role": "authenticated" } sur le template).
CLERK_JWT_TEMPLATE_SUPABASE=supabase

# -----------------------------------------------------------------------------
# Supabase (Postgres + Realtime + Storage)
# Dashboard : https://supabase.com/dashboard
# -----------------------------------------------------------------------------
# ⚠️ PR #3 prérequis : activer Third-Party Auth Clerk dans le dashboard Supabase
# (Authentication → Providers → Third-Party Auth → Add Clerk) avec CLERK_ISSUER
# et CLERK_JWKS_URL ci-dessus. Sans cette activation, auth.jwt() ->> 'sub'
# retourne NULL et toutes les policies RLS user-aware bloquent l'accès.

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...
# Uniquement serveur / CI / scripts — jamais exposé au navigateur
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# Optionnel : ID projet (scripts, MCP, support)
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Postgres (Drizzle) — TOUT via le pooler Supavisor (jamais direct)
# -----------------------------------------------------------------------------
# ⚠️ Depuis 2024, db.<ref>.supabase.co est devenu IPv6-only par défaut. L'IPv4
# en direct est un addon payant ($4/mois). Pour rester gratuit ET compatible
# CI/CD IPv4-only (GitHub Actions, Vercel build), on utilise EXCLUSIVEMENT le
# pooler Supavisor (aws-0-<region>.pooler.supabase.com), qui sert IPv4 +
# IPv6 simultanément.
#
# Format username pooler : postgres.<project_ref> (le préfixe route vers le
# bon projet, pas l'hostname). [REGION] = eu-west-3 pour tama-academy actuel,
# à ajuster si on migre/clone le projet.

# Mode TRANSACTION (port 6543) — runtime de l'app (Vercel Functions / Server
# Actions / Server Components). Pas de prepared statements partagés → Drizzle
# DOIT être configuré avec { prepare: false } sur ce port.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Mode SESSION (port 5432) — RÉSERVÉ à drizzle-kit migrate / studio / check.
# Connexion persistante (donc advisory locks OK, prepared statements OK). Le
# pooler transaction mode (6543) casserait les advisory locks que drizzle-kit
# pose pour orchestrer les migrations.
# NE JAMAIS utiliser depuis le code applicatif.
DATABASE_DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# JWT session enfant (signing serveur — jose) — PR #3 C7
# -----------------------------------------------------------------------------
# Les enfants n'ont PAS de compte Clerk (RGPD < 13 ans + UX). Un parent
# authentifié Clerk crée un enfant via Server Action, qui signe un JWT custom
# court (max_age 1h) déposé en cookie httpOnly. Tous les accès enfant
# (/eleve/*) sont gated via verifyChildToken (PR #3 src/proxy.ts).
#
# Générer le secret (à faire UNE fois par environnement, puis reset jamais
# sauf compromission) :
#   openssl rand -base64 64
# (512 bits, brief v2 §19)
JWT_CHILD_SECRET=
JWT_CHILD_ISSUER=tama-academy
JWT_CHILD_AUDIENCE=tama-child-session
JWT_CHILD_MAX_AGE_SECONDS=3600

# -----------------------------------------------------------------------------
# Logging — Pino structuré JSON (PR #3 C8)
# -----------------------------------------------------------------------------
# Niveau de log appliqué par le logger Pino. Valeurs : trace | debug | info |
# warn | error | fatal | silent. En production, 'info'. En dev local, 'debug'
# pour voir les requêtes Drizzle + Clerk + JWT.
#
# Le logger détecte le runtime à l'init :
#   - Node runtime (App routes nodejs)  → pino + pino-pretty en dev
#   - Edge runtime (proxy.ts, certaines routes) → fallback console.* JSON
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# next-intl (si chemins locales par préfixe)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DEFAULT_LOCALE=fr
# NEXT_PUBLIC_LOCALES=fr,en,ar,es

# -----------------------------------------------------------------------------
# Observabilité
# -----------------------------------------------------------------------------
# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# Sprint ultérieur — laisser vide en Sprint 0
# Listé ici pour que Samir pré-remplisse au fil de l'eau (pas de second
# .env.example à maintenir).
# =============================================================================

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting, cache éphémère — Sprint 1)
# Dashboard : https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Stripe (paiements — Sprint ultérieur)
# Dashboard : https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend (emails transactionnels — Sprint ultérieur)
# Dashboard : https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tamaacademy.fr

# -----------------------------------------------------------------------------
# DigitalSamba (visio Stage — Sprint 4)
# Dashboard : https://dashboard.digitalsamba.com
# -----------------------------------------------------------------------------
DIGITALSAMBA_TEAM_ID=
DIGITALSAMBA_DEVELOPER_KEY=
