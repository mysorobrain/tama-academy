# =============================================================================
# Tama Academy — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Build / output
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Tests / coverage
# -----------------------------------------------------------------------------
coverage/
*.lcov
playwright-report/
playwright/.cache/
test-results/
.vitest/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# -----------------------------------------------------------------------------
# Environnement — ne JAMAIS committer .env.local ni les variantes
# .env.example est suivi (template public)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Éditeurs / OS
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
.sentryclirc
.env.sentry-build-plugin

# -----------------------------------------------------------------------------
# Drizzle (caches locaux uniquement — les migrations sont commitées)
# -----------------------------------------------------------------------------
.drizzle/

# -----------------------------------------------------------------------------
# Local artefacts
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.cache/
.turbo/
